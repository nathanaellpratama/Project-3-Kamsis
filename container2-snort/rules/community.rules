# ============================================
# COMMUNITY RULES - Snort Community Ruleset
# These rules are downloaded from Snort.org
# To update: run /opt/scripts/update-rules.sh
# ============================================
# Note: This file contains a subset of community
# rules. Run update-rules.sh to download the full
# community ruleset from snort.org
# ============================================

# --- Malware/Trojan Detection ---
alert tcp $HOME_NET any -> $EXTERNAL_NET any (msg:"[COMMUNITY] Possible trojan outbound connection"; flow:to_server,established; content:"X-Bot"; nocase; sid:2000001; rev:1; classtype:trojan-activity; priority:1;)

# --- Shellcode Detection ---
alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"[COMMUNITY] Possible shellcode - NOP sled detected"; content:"|90 90 90 90 90 90 90 90 90 90 90 90 90 90 90 90|"; sid:2000002; rev:1; classtype:shellcode-detect; priority:1;)

# --- Web Server Attacks ---
alert tcp $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS (msg:"[COMMUNITY] Web attack - /etc/passwd access attempt"; flow:to_server,established; content:"/etc/passwd"; nocase; sid:2000003; rev:1; classtype:web-application-attack; priority:1;)

alert tcp $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS (msg:"[COMMUNITY] Web attack - /etc/shadow access attempt"; flow:to_server,established; content:"/etc/shadow"; nocase; sid:2000004; rev:1; classtype:web-application-attack; priority:1;)

alert tcp $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS (msg:"[COMMUNITY] Web attack - Directory traversal attempt"; flow:to_server,established; content:"../"; content:"../"; distance:0; sid:2000005; rev:1; classtype:web-application-attack; priority:2;)

alert tcp $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS (msg:"[COMMUNITY] Web attack - Command injection (;ls)"; flow:to_server,established; content:";"; content:"ls"; distance:0; within:5; sid:2000006; rev:1; classtype:web-application-attack; priority:1;)

alert tcp $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS (msg:"[COMMUNITY] Web attack - Command injection (|cat)"; flow:to_server,established; content:"|"; content:"cat"; distance:0; within:10; sid:2000007; rev:1; classtype:web-application-attack; priority:1;)

# --- Suspicious User Agents ---
alert tcp $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS (msg:"[COMMUNITY] Suspicious User-Agent - Python-urllib"; flow:to_server,established; content:"python-urllib"; nocase; sid:2000008; rev:1; classtype:policy-violation; priority:3;)

alert tcp $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS (msg:"[COMMUNITY] Suspicious User-Agent - curl"; flow:to_server,established; content:"User-Agent|3A| curl"; nocase; sid:2000009; rev:1; classtype:policy-violation; priority:3;)

# --- DNS Anomalies ---
alert udp any any -> any 53 (msg:"[COMMUNITY] DNS - Unusually long DNS query"; dsize:>512; sid:2000010; rev:1; classtype:bad-unknown; priority:2;)

# --- SSH Brute Force ---
alert tcp $EXTERNAL_NET any -> $HOME_NET 22 (msg:"[COMMUNITY] SSH brute force attempt"; flow:to_server,established; threshold:type threshold,track by_src,count 5,seconds 60; sid:2000011; rev:1; classtype:attempted-admin; priority:1;)

# --- FTP Attacks ---
alert tcp $EXTERNAL_NET any -> $HOME_NET 21 (msg:"[COMMUNITY] FTP brute force attempt"; flow:to_server,established; threshold:type threshold,track by_src,count 5,seconds 60; sid:2000012; rev:1; classtype:attempted-admin; priority:1;)

# --- Potential Data Exfiltration ---
alert tcp $HOME_NET any -> $EXTERNAL_NET any (msg:"[COMMUNITY] Possible data exfiltration - Large outbound transfer"; flow:to_server,established; dsize:>50000; threshold:type threshold,track by_src,count 5,seconds 60; sid:2000013; rev:1; classtype:policy-violation; priority:2;)
