# ============================================
# LOCAL RULES - Custom Detection Rules
# Container 2: Snort IDS/IPS
# Project 3 - Keamanan Sistem
# ============================================
# Rule Actions:
#   alert  = IDS mode (log only, monitoring)
#   drop   = IPS mode (block + log)
#   reject = IPS mode (block + send RST/ICMP unreachable)
# ============================================

# ==========================================
# SQL INJECTION DETECTION (sid:1000001-1000010)
# ==========================================

# Detect UNION SELECT injection
drop tcp any any -> $HOME_NET $HTTP_PORTS (msg:"[LOCAL] SQL Injection - UNION SELECT detected"; flow:to_server,established; content:"UNION"; nocase; content:"SELECT"; nocase; distance:0; within:20; sid:1000001; rev:1; classtype:web-application-attack; priority:1; metadata:policy security-ips drop;)

# Detect OR 1=1 injection
drop tcp any any -> $HOME_NET $HTTP_PORTS (msg:"[LOCAL] SQL Injection - OR 1=1 detected"; flow:to_server,established; content:"OR"; nocase; content:"1=1"; distance:0; within:10; sid:1000002; rev:1; classtype:web-application-attack; priority:1;)

# Detect DROP TABLE injection
drop tcp any any -> $HOME_NET $HTTP_PORTS (msg:"[LOCAL] SQL Injection - DROP TABLE detected"; flow:to_server,established; content:"DROP"; nocase; content:"TABLE"; nocase; distance:0; within:10; sid:1000003; rev:1; classtype:web-application-attack; priority:1;)

# Detect single-quote based injection
alert tcp any any -> $HOME_NET $HTTP_PORTS (msg:"[LOCAL] SQL Injection - Single quote attack attempt"; flow:to_server,established; content:"'"; content:"OR"; nocase; distance:0; within:10; sid:1000004; rev:1; classtype:web-application-attack; priority:2;)

# Detect comment-based injection (--)
alert tcp any any -> $HOME_NET $HTTP_PORTS (msg:"[LOCAL] SQL Injection - SQL comment (--) detected"; flow:to_server,established; content:"--"; content:"SELECT"; nocase; sid:1000005; rev:1; classtype:web-application-attack; priority:2;)

# Detect INSERT INTO injection
drop tcp any any -> $HOME_NET $HTTP_PORTS (msg:"[LOCAL] SQL Injection - INSERT INTO detected"; flow:to_server,established; content:"INSERT"; nocase; content:"INTO"; nocase; distance:0; within:10; sid:1000006; rev:1; classtype:web-application-attack; priority:1;)

# Detect DELETE FROM injection
drop tcp any any -> $HOME_NET $HTTP_PORTS (msg:"[LOCAL] SQL Injection - DELETE FROM detected"; flow:to_server,established; content:"DELETE"; nocase; content:"FROM"; nocase; distance:0; within:10; sid:1000007; rev:1; classtype:web-application-attack; priority:1;)

# Detect hex-encoded injection
alert tcp any any -> $HOME_NET $HTTP_PORTS (msg:"[LOCAL] SQL Injection - Hex encoding detected (0x)"; flow:to_server,established; content:"0x"; content:"SELECT"; nocase; sid:1000008; rev:1; classtype:web-application-attack; priority:2;)

# Detect EXEC/EXECUTE injection
drop tcp any any -> $HOME_NET $HTTP_PORTS (msg:"[LOCAL] SQL Injection - EXEC command detected"; flow:to_server,established; content:"EXEC"; nocase; content:"("; distance:0; within:15; sid:1000009; rev:1; classtype:web-application-attack; priority:1;)

# Detect sqlmap user-agent
drop tcp any any -> $HOME_NET $HTTP_PORTS (msg:"[LOCAL] SQL Injection Tool - sqlmap detected"; flow:to_server,established; content:"sqlmap"; nocase; sid:1000010; rev:1; classtype:web-application-attack; priority:1;)

# ==========================================
# XSS DETECTION (sid:1000011-1000020)
# ==========================================

# Detect <script> tag injection
drop tcp any any -> $HOME_NET $HTTP_PORTS (msg:"[LOCAL] XSS - Script tag detected"; flow:to_server,established; content:"<script"; nocase; sid:1000011; rev:1; classtype:web-application-attack; priority:1;)

# Detect javascript: URI
drop tcp any any -> $HOME_NET $HTTP_PORTS (msg:"[LOCAL] XSS - javascript: URI detected"; flow:to_server,established; content:"javascript|3A|"; nocase; sid:1000012; rev:1; classtype:web-application-attack; priority:1;)

# Detect onerror= event handler
drop tcp any any -> $HOME_NET $HTTP_PORTS (msg:"[LOCAL] XSS - onerror event handler detected"; flow:to_server,established; content:"onerror"; nocase; content:"="; distance:0; within:5; sid:1000013; rev:1; classtype:web-application-attack; priority:1;)

# Detect onload= event handler
drop tcp any any -> $HOME_NET $HTTP_PORTS (msg:"[LOCAL] XSS - onload event handler detected"; flow:to_server,established; content:"onload"; nocase; content:"="; distance:0; within:5; sid:1000014; rev:1; classtype:web-application-attack; priority:1;)

# Detect onmouseover= event handler
alert tcp any any -> $HOME_NET $HTTP_PORTS (msg:"[LOCAL] XSS - onmouseover event handler detected"; flow:to_server,established; content:"onmouseover"; nocase; content:"="; distance:0; within:5; sid:1000015; rev:1; classtype:web-application-attack; priority:2;)

# Detect eval() function
drop tcp any any -> $HOME_NET $HTTP_PORTS (msg:"[LOCAL] XSS - eval() function detected"; flow:to_server,established; content:"eval("; nocase; sid:1000016; rev:1; classtype:web-application-attack; priority:1;)

# Detect document.cookie access
drop tcp any any -> $HOME_NET $HTTP_PORTS (msg:"[LOCAL] XSS - document.cookie access detected"; flow:to_server,established; content:"document.cookie"; nocase; sid:1000017; rev:1; classtype:web-application-attack; priority:1;)

# Detect <img src=x onerror> pattern
drop tcp any any -> $HOME_NET $HTTP_PORTS (msg:"[LOCAL] XSS - IMG tag XSS attempt"; flow:to_server,established; content:"<img"; nocase; content:"onerror"; nocase; distance:0; within:50; sid:1000018; rev:1; classtype:web-application-attack; priority:1;)

# Detect <svg onload> pattern
drop tcp any any -> $HOME_NET $HTTP_PORTS (msg:"[LOCAL] XSS - SVG onload XSS attempt"; flow:to_server,established; content:"<svg"; nocase; content:"onload"; nocase; distance:0; within:50; sid:1000019; rev:1; classtype:web-application-attack; priority:1;)

# Detect alert() function in requests
alert tcp any any -> $HOME_NET $HTTP_PORTS (msg:"[LOCAL] XSS - alert() function in request"; flow:to_server,established; content:"alert("; nocase; sid:1000020; rev:1; classtype:web-application-attack; priority:2;)

# ==========================================
# PORT SCAN DETECTION (sid:1000021-1000030)
# ==========================================

# Detect nmap SYN scan
alert tcp any any -> $HOME_NET any (msg:"[LOCAL] Port Scan - Nmap SYN scan detected"; flags:S; sid:1000021; rev:1; classtype:attempted-recon; priority:2;)

# Detect nmap FIN scan
alert tcp any any -> $HOME_NET any (msg:"[LOCAL] Port Scan - FIN scan detected"; flags:F; sid:1000022; rev:1; classtype:attempted-recon; priority:2;)

# Detect nmap XMAS scan
alert tcp any any -> $HOME_NET any (msg:"[LOCAL] Port Scan - XMAS scan detected"; flags:FPU; sid:1000023; rev:1; classtype:attempted-recon; priority:2;)

# Detect nmap NULL scan
alert tcp any any -> $HOME_NET any (msg:"[LOCAL] Port Scan - NULL scan detected"; flags:0; sid:1000024; rev:1; classtype:attempted-recon; priority:2;)

# Detect nmap user-agent
alert tcp any any -> $HOME_NET $HTTP_PORTS (msg:"[LOCAL] Recon - Nmap HTTP scan detected"; flow:to_server,established; content:"Nmap"; nocase; sid:1000025; rev:1; classtype:attempted-recon; priority:2;)

# Detect nikto scanner
drop tcp any any -> $HOME_NET $HTTP_PORTS (msg:"[LOCAL] Recon - Nikto scanner detected"; flow:to_server,established; content:"Nikto"; nocase; sid:1000026; rev:1; classtype:web-application-attack; priority:1;)

# Detect rapid connection attempts (port sweep)
alert tcp any any -> $HOME_NET any (msg:"[LOCAL] Port Scan - Rapid connection attempts"; flags:S; sid:1000027; rev:1; classtype:attempted-recon; priority:1;)

# ==========================================
# DoS / DDoS DETECTION (sid:1000031-1000040)
# ==========================================

# Detect SYN flood
drop tcp any any -> $HOME_NET any (msg:"[LOCAL] DoS - SYN flood detected"; flags:S; sid:1000031; rev:1; classtype:attempted-dos; priority:1;)

# Detect HTTP flood
drop tcp any any -> $HOME_NET $HTTP_PORTS (msg:"[LOCAL] DoS - HTTP flood detected"; flow:to_server,established; sid:1000032; rev:1; classtype:attempted-dos; priority:1;)

# Detect ICMP flood
drop icmp any any -> $HOME_NET any (msg:"[LOCAL] DoS - ICMP flood detected"; sid:1000033; rev:1; classtype:attempted-dos; priority:1;)

# Detect large ICMP packet (ping of death attempt)
drop icmp any any -> $HOME_NET any (msg:"[LOCAL] DoS - Large ICMP packet (Ping of Death)"; dsize:>1000; sid:1000034; rev:1; classtype:attempted-dos; priority:1;)

# ==========================================
# BUFFER OVERFLOW DETECTION (sid:1000041-1000050)
# ==========================================

# Detect oversized HTTP request URI
alert tcp any any -> $HOME_NET $HTTP_PORTS (msg:"[LOCAL] Buffer Overflow - Oversized HTTP URI"; flow:to_server,established; urilen:>2048; sid:1000041; rev:1; classtype:web-application-attack; priority:1;)

# Detect oversized HTTP header
alert tcp any any -> $HOME_NET $HTTP_PORTS (msg:"[LOCAL] Buffer Overflow - Oversized HTTP header"; flow:to_server,established; content:"Host|3A|"; content:!"|0D 0A|"; within:8192; sid:1000042; rev:1; classtype:web-application-attack; priority:2;)

# Detect very long content in POST
alert tcp any any -> $HOME_NET $HTTP_PORTS (msg:"[LOCAL] Buffer Overflow - Large POST data"; flow:to_server,established; content:"POST"; depth:4; dsize:>65535; sid:1000043; rev:1; classtype:web-application-attack; priority:1;)

# ==========================================
# BRUTE FORCE DETECTION (sid:1000051-1000060)
# ==========================================

# Detect login brute force
alert tcp any any -> $HOME_NET $HTTP_PORTS (msg:"[LOCAL] Brute Force - Multiple login attempts"; flow:to_server,established; content:"POST"; depth:4; content:"/login"; content:"username"; sid:1000051; rev:1; classtype:attempted-admin; priority:1;)

# ==========================================
# GENERAL / ICMP (sid:1000061-1000070)
# ==========================================

# Detect ICMP ping (monitoring)
alert icmp any any -> $HOME_NET any (msg:"[LOCAL] ICMP - Ping to web server detected"; itype:8; sid:1000061; rev:1; classtype:icmp-event; priority:3;)

# Detect ICMP ping response
alert icmp $HOME_NET any -> any any (msg:"[LOCAL] ICMP - Ping reply from web server"; itype:0; sid:1000062; rev:1; classtype:icmp-event; priority:3;)
